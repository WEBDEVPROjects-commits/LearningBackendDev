<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Tailwind Registration Form</title>

  <!-- Tailwind CSS CDN -->
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>

<body class="bg-gray-100 min-h-screen flex items-center justify-center">

  <div class="bg-white w-full max-w-md p-8 rounded-2xl shadow-lg">

    <h2 class="text-3xl font-bold text-center mb-6">
      Registration Form
    </h2>

    <form class="space-y-4" action="/create" method="post">

      <!-- Full Name -->
      <div>
        <label class="block mb-1 font-medium">
          Full Name
        </label>

        <input
          type="text"
          placeholder="Enter your full name"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          name="Name"
        />
      </div>

      <!-- Username -->
      <div>
        <label class="block mb-1 font-medium">
          Username
        </label>

        <input
          type="text"
          placeholder="Enter username"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          name="Username"
        />
      </div>

      <!-- Email -->
      <div>
        <label class="block mb-1 font-medium">
          Email
        </label>

        <input
          type="email"
          placeholder="Enter email"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          name="Email"
        />
      </div>

      <!-- Password -->
      <div>
        <label class="block mb-1 font-medium">
          Password
        </label>

        <input
          type="password"
          placeholder="Enter password"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500"
          name="Password"
        />
      </div>

      <!-- Checkbox -->
      <div class="flex items-start gap-2">
        <input type="checkbox" class="mt-1">

        <p class="text-sm text-gray-600">
          I agree to the Terms & Conditions
        </p>
      </div>

      <!-- Button -->
      <button
        type="submit"
        class="w-full bg-blue-600 hover:bg-blue-700 text-white py-3 rounded-lg font-semibold transition duration-300"
      >
        Register
      </button>

      <!-- Login -->
      <p class="text-center text-sm text-gray-600">
        Already have an account?
        <a href="/login" class="text-blue-600 hover:underline">
          Login
        </a>
      </p>

    </form>
  </div>

</body>
</html>