<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Notes</title>
    <!-- <link rel="stylesheet" href="./style.css"> -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body>
    <div class="main w-full min-h-screen bg-zinc-900 text-white">
        <div class="form p-10">
            <form action="/create" method="post">
                <input class="block w-full rounded-md px-5 py-2 bg-zinc-800 outline-none" type="text" name="title"
                    placeholder="Title">
                <textarea class="block px-5 w-full rounded-md mt-2 py-2 bg-zinc-800 resize-none outline-none"
                    name="details" placeholder="Write your task details here"></textarea>
                <input class="mt-2 bg-blue-600 px-5 py-2" type="submit" value="Create Task">
            </form>
        </div>
        <div class="tasks flex gap-3 flex-wrap p-10">
            <% if(files.length>0){%>
                <% files.forEach((value)=>{ %>
                    <% console.log(files)%>
                    <div class="task min-w-72 px-3 py-4 bg-zinc-800 rounded-md">
                        <h1 class="text-white text-3xl tracking-tight"><%= value%></h1>

                        <div class="flex w-full justify-between items-center mt-3">
                            <a class="text-blue-500 inline-block" href="/files/<%= value%>">Read more</a>
                            <a class="text-zinc-600" href="/edit/<%= value%>">Edit filename</a>
                        </div>

                        </div>
                    <%}) %>
                        <% } else {%>
                            <h3 class="text-zinc-600">No task yet.</h3>
                            <% } %>
        </div>
    </div>
</body>

</html>